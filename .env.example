# مفتاح حماية جلسات Flask.
# استخدم قيمة طويلة وعشوائية في ملف .env الحقيقي.
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# مفتاح توقيع JWT.
# استخدم قيمة مختلفة عن FLASK_SECRET_KEY.
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret

# اجعلها false في العرض أو الإنتاج، وtrue فقط أثناء التطوير.
FLASK_DEBUG=false

# اختياري: مطلوب فقط عند استخدام AI Analysis.
OPENAI_API_KEY=your-openai-api-key

# اختياري: مطلوب فقط إذا تم استخدام إرسال البريد أو OTP.
EMAIL_SENDER=your-email@example.com
EMAIL_APP_PASSWORD=your-email-app-password

# حماية بسيطة ضد تكرار محاولات login/register.
AUTH_RATE_LIMIT_WINDOW=300
AUTH_RATE_LIMIT_MAX=5
