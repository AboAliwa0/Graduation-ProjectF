# Copy to .env, then run: python scripts/generate_secrets.py
# SECRET_KEY is a compatibility alias; FLASK_SECRET_KEY takes precedence.
SECRET_KEY=
FLASK_SECRET_KEY=
JWT_SECRET_KEY=
FLASK_ENV=production
DEBUG=false
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000
SESSION_COOKIE_SECURE=false
ENABLE_HSTS=false
MAX_CONTENT_LENGTH=4194304
SESSION_LIFETIME_HOURS=8
JWT_ACCESS_MINUTES=30
DATABASE_PATH=data/scanner.db

# Execution controls
SCAN_WORKERS=4
MAX_ACTIVE_SCANS_PER_USER=2
DEFAULT_REQUEST_BUDGET=120
MAX_REQUEST_BUDGET=500
SCANNER_TIMEOUT=8
SCANNER_MAX_REDIRECTS=3
SCANNER_MAX_RESPONSE_BYTES=2097152
SCANNER_USER_AGENT=CyberScan/5.0 Authorized-Security-Assessment


# Queue backend: local (default) or redis. Redis jobs are encrypted at rest in the queue.
SCAN_QUEUE_BACKEND=local
REDIS_URL=redis://redis:6379/0
QUEUE_ENCRYPTION_KEY=
SOCKETIO_MESSAGE_QUEUE=
WORKER_POLL_SECONDS=5
WORKER_HEARTBEAT_TTL=30
REDIS_CONNECT_TIMEOUT=3
REDIS_SOCKET_TIMEOUT=5
REDIS_SCAN_QUEUE_KEY=cyberscan:scan_jobs:v1
REDIS_CANCEL_PREFIX=cyberscan:cancel:
REDIS_PROCESSING_PREFIX=cyberscan:processing:
REDIS_HEARTBEAT_PREFIX=cyberscan:worker-heartbeat:

# Scope controls. Example: example.com,*.staging.example.com
SCAN_ALLOWED_HOSTS=
REQUIRE_TARGET_SCOPE=false

# Safety defaults. Keep private targets disabled outside an isolated local lab.
ALLOW_PRIVATE_TARGETS=false
ALLOW_INSECURE_TLS=false

# Public URL of this CyberScan instance for SSRF / Blind-XSS callback verification.
# Example inside an isolated lab: http://127.0.0.1:5000
OAST_PUBLIC_BASE_URL=
OAST_ALLOW_PRIVATE_CALLBACKS=false

# Optional Playwright overrides. Leave the executable blank to use the managed browser.
PLAYWRIGHT_CHROMIUM_EXECUTABLE=
PLAYWRIGHT_DISABLE_SANDBOX=false

AUTH_RATE_LIMIT_WINDOW=300
AUTH_RATE_LIMIT_MAX=5
SOCKET_ALLOWED_ORIGINS=
TRUST_PROXY_HEADERS=false
ALLOW_UNSAFE_WERKZEUG=true
